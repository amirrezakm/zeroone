.DS_Store
__pycache__/
*.pyc
*.pyo
*.swp

# Live host snapshot — never tracked in public repo.
/rootfs/

# Local live source-of-truth generated from server snapshot
config/stack.local.json

# Environment / secrets
/.env
/.env.local
/opt-zeroone-local/

# Old backups from server
*.bak
*.bak-*
*.tmp-*

# Full server config snapshots kept local-only until sanitized/reviewed
server-snapshots/

# UI build/runtime artifacts
web/app/node_modules/
web/app/dist/
web/app/tsconfig.tsbuildinfo
web/app/.vite/

# Build output
dist/

# Local-built binaries
/edge-relay
/zeroone
/cmd/edge-relay/edge-relay
/cmd/zeroone/zeroone

# Test/coverage
coverage.out
*.pprof

# Release archives
*.tar.gz

# Internal-only docs (not for public)
docs/internal/
