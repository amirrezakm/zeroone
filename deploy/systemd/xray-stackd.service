[Unit]
Description=Xray Stack Go Control Plane
After=network-online.target xray.service openvpn@company.service openvpn@client-tun1.service
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=-/etc/default/xray-stackd
ExecStart=/usr/local/bin/xray-stackd -config /usr/local/etc/xray-stack/stack.json $XRAY_STACKD_FLAGS
Restart=always
RestartSec=5
User=root
LimitNOFILE=1048576
TasksMax=infinity

[Install]
WantedBy=multi-user.target
