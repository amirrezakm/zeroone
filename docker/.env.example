# Image tag — pin to a specific version in production.
# Examples: latest, v0.1.0
ZEROONE_VERSION=latest

# Panel listen address (inside the container's host-net namespace).
# Use 127.0.0.1:PORT to bind to loopback only (and front with nginx/caddy
# for public TLS); use 0.0.0.0:PORT for direct exposure (only behind a
# firewall + TLS).
ZEROONE_ADMIN_LISTEN=0.0.0.0:8000
ZEROONE_ADMIN_LISTEN_PORT=8000

# Optional: bandwidth-shaping device. Leave empty in container mode
# unless you also opt into nft/tc tooling on the host.
# ZEROONE_BANDWIDTH_DEVICE=eth0

# Timezone for log timestamps and daily quota resets.
TZ=UTC
