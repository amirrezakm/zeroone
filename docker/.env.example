# Image source — defaults to the upstream GHCR image. Override when
# running from a fork that publishes its own image (e.g.
# ghcr.io/<your-fork>/zeroone). The installer pins this automatically
# when ZEROONE_REPO or ZEROONE_IMAGE is set in its environment.
# ZEROONE_IMAGE=ghcr.io/amirrezakm/zeroone

# Image tag — pin to a specific version in production.
# Examples: latest, v0.1.0
ZEROONE_VERSION=latest

# Panel listen address (inside the container's host-net namespace).
# Use 127.0.0.1:PORT to bind to loopback only (and front with nginx/caddy
# for public TLS); use 0.0.0.0:PORT for direct exposure (only behind a
# firewall + TLS).
ZEROONE_ADMIN_LISTEN=0.0.0.0:8000
ZEROONE_ADMIN_LISTEN_PORT=8000

# Optional: bandwidth-shaping device. Leave empty in container mode
# unless you also opt into nft/tc tooling on the host.
# ZEROONE_BANDWIDTH_DEVICE=eth0

# Timezone for log timestamps and daily quota resets.
TZ=UTC

# Xray runtime update mirrors. The image already ships xray, so these
# are only used by the panel "Update Xray" flow (Settings → Xray
# runtime). Leave empty to hit GitHub directly; set to a regional
# mirror (Iranian PaaS, ghproxy, ...) when GitHub is blocked. The
# mirror must expose the same `<version>/<asset>` layout that GitHub
# Releases uses.
# ZEROONE_XRAY_RELEASE_MIRROR=https://mirror.example.com/Xray-core/releases/download
# ZEROONE_XRAY_ASSETS_MIRROR=https://mirror.example.com/v2fly
